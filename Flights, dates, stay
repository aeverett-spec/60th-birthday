<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&display=swap" rel="stylesheet">

<style>
  body {
    font-family: 'Montserrat', sans-serif;
    background-color: transparent;
    margin: 0;
    padding: 10px;
    display: flex;
    justify-content: center;
  }
  
  .container {
    display: flex;
    flex-direction: row;
    gap: 25px;
    max-width: 1000px;
    width: 100%;
  }
  
  .card {
    flex: 1;
    position: relative;
    height: 320px;
    border-radius: 24px;
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
  }

  /* The image containers fill the card exactly */
  .card-front {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 1;
    transition: opacity 0.3s ease;
  }
  
  .card-icon {
    width: 100%; 
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  /* The hidden text back layer */
  .card-back {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 2;
    opacity: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 24px;
    box-sizing: border-box;
    color: white;
    text-align: center;
    transition: opacity 0.3s ease;
  }

  /* Specific dark tint backgrounds for text contrast */
  .flights .card-back { background-color: rgba(211, 93, 59, 0.92); }
  .dates .card-back { background-color: rgba(78, 110, 133, 0.92); }
  .stay .card-back { background-color: rgba(234, 164, 70, 0.92); }

  /* Hover Actions */
  .card:hover .card-front { opacity: 0; }
  .card:hover .card-back { opacity: 1; }

  /* Typography */
  .back-title {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 10px 0;
  }
  
  .back-text {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
  }

  /* Mobile Layout Stacking */
  @media (max-width: 768px) {
    .container {
      flex-direction: column;
      align-items: center;
    }
    .card {
      width: 100%;
      max-width: 340px;
    }
  }
</style>
</head>
<body>

<div class="container">
  
  <div class="card flights">
    <div class="card-front">
      <img src="https://images.squarespace-cdn.com/content/v1/69ab3f0184767f29723e1488/88afa449-42b9-4890-94c9-661387f57632/Flights.png?format=500w" alt="Flights" class="card-icon">
    </div>
    <div class="card-back">
      <h3 class="back-title">Flight Details</h3>
      <p class="back-text">Ready for takeoff?<br>Check back soon for final gate and routing updates.</p>
    </div>
  </div>

  <div class="card dates">
    <div class="card-front">
      <img src="https://images.squarespace-cdn.com/content/v1/69ab3f0184767f29723e1488/e895b82a-8fa6-4cd6-b0c4-92cd382a7f4a/Dates.png?format=500w" alt="Dates" class="card-icon">
    </div>
    <div class="card-back">
      <h3 class="back-title">Mark Your Calendar</h3>
      <p class="back-text">The countdown is officially on. Make sure your out-of-office notification is set!</p>
    </div>
  </div>

  <div class="card stay">
    <div class="card-front">
      <img src="https://images.squarespace-cdn.com/content/v1/69ab3f0184767f29723e1488/d67a7e2c-f369-4de4-8ef9-02bad28e4af5/Where+You%27ll+Stay.png?format=500w" alt="Where You'll Stay" class="card-icon">
    </div>
    <div class="card-back">
      <h3 class="back-title">Your Accommodations</h3>
      <p class="back-text">We've picked out a gorgeous spot. Complete check-in details are coming shortly.</p>
    </div>
  </div>

</div>

</body>
</html>
